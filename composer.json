{
    "name": "larsmarkus-studio/craft-moneybird",
    "description": "Moneybird OAuth authentication and API service classes for Craft CMS 5.",
    "type": "craft-plugin",
    "license": "MIT",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "moneybird",
        "oauth",
        "accounting"
    ],
    "support": {
        "source": "https://github.com/larsmarkus-studio/craft-moneybird",
        "issues": "https://github.com/larsmarkus-studio/craft-moneybird/issues"
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.6.0",
        "league/oauth2-client": "^2.8"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "larsmarkusstudio\\moneybird\\": "src/"
        }
    },
    "extra": {
        "handle": "craft-moneybird",
        "name": "Moneybird",
        "developer": "Lars Markus",
        "developerUrl": "https://larsmarkus.studio",
        "documentationUrl": "https://github.com/larsmarkus-studio/craft-moneybird",
        "class": "larsmarkusstudio\\moneybird\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "phpstan": "phpstan --ansi --memory-limit=1G",
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --fix --ansi"
    }
}
